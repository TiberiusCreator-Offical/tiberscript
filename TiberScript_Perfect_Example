// Global configuration using a data block.
// Data blocks define static game settings in one place.
game_config = data
  title = "Tiberian Odyssey"
  version = "1.0.0"
  initial_player_hp = 100
  player_move_speed = 3
  enemy_damage = 10
  heal_potion_amount = 25
  max_crystals = 5
  music_main_theme = "main_theme_tune"
  sfx_hit = "hit_sound"
  sfx_collect = "collect_sound"
  sfx_heal = "heal_sound"
  sfx_victory = "victory_fanfare"
  sfx_game_over = "game_over_buzz"
  sfx_save = "save_game_chime"
  sfx_risky_action = "risky_beep"
  sfx_risky_fail = "fail_sound"
end

// Player archetype.
// Archetypes are TiberScript's way of defining blueprints for game objects.
// mark() tags an object for collision and proximity detection.
player_archetype = archetype
  init(name_given) = function
    this.name = name_given
    this.hp = game_config.initial_player_hp
    this.x = 100
    this.y = 100
    this.score = 0
    this.crystals_found = 0
    this.inventory = ["Heal Potion", "Heal Potion"]
    this.damaged = false
    this.mark("player")
    print("Player '" + this.name + "' created with " + this.hp + " HP.")
  end

  // Movement using key().held for continuous input.
  // clamp() keeps the player inside screen bounds.
  move() = function
    local moved = false
    if key("arrowRight").held then this.x += game_config.player_move_speed moved = true end
    if key("arrowLeft").held  then this.x -= game_config.player_move_speed moved = true end
    if key("arrowUp").held    then this.y -= game_config.player_move_speed moved = true end
    if key("arrowDown").held  then this.y += game_config.player_move_speed moved = true end
    this.x = clamp(this.x, 20, 300)
    this.y = clamp(this.y, 20, 200)
    return moved
  end

  // Checks for nearby NPCs and lets the player talk to them.
  // near() returns the closest object with the given tag within range.
  interact() = function
    local npc = near("npc", 50)
    if npc then
      screen.text("Press E to talk to " + npc.name)
      if key("e").hit then
        sfx("button_press")
        npc.talk()
      end
    end
  end

  // Reduces HP, plays a sound, emits particles, and checks for death.
  take_damage(amount) = function
    this.hp = this.hp - amount
    this.damaged = true
    sfx(game_config.sfx_hit)
    emit("impact_particles", this.x, this.y, 3)
    print(this.name + " took " + amount + " damage. HP: " + this.hp)
    if this.hp <= 0 then
      transit("gameOver")
    end
  end

  // Uses a healing potion from the inventory if available.
  use_potion() = function
    local potion_index = this.inventory.indexOf("Heal Potion")
    if potion_index >= 0 and this.hp < game_config.initial_player_hp then
      this.inventory.removeAt(potion_index)
      this.hp = min(this.hp + game_config.heal_potion_amount, game_config.initial_player_hp)
      sfx(game_config.sfx_heal)
      emit("heal_particles", this.x, this.y, 10)
      print(this.name + " used a potion. HP: " + this.hp)
    elsetry potion_index < 0 then
      print("No healing potions left!")
    else
      print("Already at full health!")
    end
  end

  // Saves game progress to a named slot using the access block.
  // The slot saves automatically when the access block closes.
  save_progress() = function
    access "crystal_quest_save" as file do
      file.player_name = this.name
      file.player_hp = this.hp
      file.player_x = this.x
      file.player_y = this.y
      file.player_score = this.score
      file.crystals_found = this.crystals_found
      print("Game saved!")
      sfx(game_config.sfx_save)
    end
  end

  // Loads game progress from a previously saved slot.
  load_progress() = function
    if exists("crystal_quest_save") then
      access "crystal_quest_save" as file do
        this.name = file.player_name
        this.hp = file.player_hp
        this.x = file.player_x
        this.y = file.player_y
        this.score = file.player_score
        this.crystals_found = file.crystals_found
        print("Game loaded!")
        sfx(game_config.sfx_save)
      end
    else
      print("No save file found!")
    end
  end

  // Draws the player. Uses alter to flash red briefly when damaged.
  draw() = function
    if this.damaged then
      alter color="red", opacity=0.7, scale=1.2 do
        screen.sprite("player_sprite", this.x, this.y, 32)
      end
      this.damaged = false
    else
      screen.sprite("player_sprite", this.x, this.y, 32)
    end
    screen.text("HP: " + this.hp)
  end
end

// Enemy archetype.
// Moves toward the player when close and deals damage on contact.
enemy_archetype = archetype
  init(id_num) = function
    this.id = "Enemy " + id_num
    this.x = random(50, 250)
    this.y = random(50, 150)
    this.speed = random(1, 2)
    this.mark("enemy")
    this.alive = true
  end

  update(target_x, target_y) = function
    if not this.alive then return end
    local dist = distance(this.x, this.y, target_x, target_y)
    if dist < 150 then
      if this.x < target_x then this.x += this.speed end
      if this.x > target_x then this.x -= this.speed end
      if this.y < target_y then this.y += this.speed end
      if this.y > target_y then this.y -= this.speed end
      local p = collide("player")
      if p then
        p.take_damage(game_config.enemy_damage)
        print(this.id + " attacked player.")
      end
    end
  end

  draw() = function
    if not this.alive then return end
    screen.sprite("enemy_sprite", this.x, this.y, 28)
  end

  // vanish() removes the object from all collision and near checks.
  die() = function
    print(this.id + " vanquished!")
    emit("explosion_particles", this.x, this.y, 20)
    sfx("enemy_explode")
    this.alive = false
    this.vanish()
  end
end

// Crystal archetype.
// Collectible items the player picks up to complete the quest.
crystal_archetype = archetype
  init(cx, cy) = function
    this.x = cx
    this.y = cy
    this.mark("collectible")
    this.collected = false
  end

  // wave() creates a smooth floating animation without manual timer logic.
  draw() = function
    if this.collected then return end
    local float_y = this.y + wave(0, 5)
    alter scale=1.0, opacity=0.9 do
      screen.sprite("crystal_sprite", this.x, float_y, 20)
    end
  end

  collect(collector) = function
    if this.collected then return end
    this.collected = true
    collector.score += 100
    collector.crystals_found += 1
    sfx(game_config.sfx_collect)
    emit("sparkle_particles", this.x, this.y, 8)
    print("Crystal collected! Score: " + collector.score)
    this.vanish()
  end
end

// Base character archetype.
// Shared by all characters in the world that can be spoken to.
character_archetype = archetype
  init(name, x, y) = function
    this.name = name
    this.x = x
    this.y = y
    this.mark("interactable")
  end

  talk() = function
    print(this.name + " says: 'Hello, traveler!'")
  end

  draw() = function
    screen.sprite("npc_base_sprite", this.x, this.y, 30)
    screen.text(this.name)
  end
end

// Quest giver NPC. Extends the base character archetype.
// super.init() calls the parent constructor before adding new behaviour.
quest_giver_npc = archetype extends character_archetype
  init() = function
    super.init("Elder Tim", 300, 200)
    this.quest_given = false
    this.mark("npc")
  end

  talk() = function
    if not this.quest_given then
      print(this.name + " says: 'Brave adventurer, the Crystal of Harmony has been shattered!")
      print("Collect " + game_config.max_crystals + " crystal shards to restore balance!'")
      this.quest_given = true
      schedule(600) = function
        print("Elder Tim whispers: 'Keep searching for those crystals!'")
      end
    elsetry player.crystals_found >= game_config.max_crystals then
      print(this.name + " says: 'You have collected all the crystals! The world is saved!'")
      transit("win")
    else
      print(this.name + " says: 'You still need " + (game_config.max_crystals - player.crystals_found) + " crystals!'")
    end
  end
end

// Global game state variables.
player = null
enemies = []
crystals = []
npcs = []

// Initialise all game objects and start the game.
init() = function
  player = new player_archetype("Hero")

  for i = 1 to 3
    enemies.push(new enemy_archetype(i))
  end

  crystals.push(new crystal_archetype(50, 50))
  crystals.push(new crystal_archetype(250, 50))
  crystals.push(new crystal_archetype(50, 150))
  crystals.push(new crystal_archetype(250, 150))
  crystals.push(new crystal_archetype(150, 100))

  npcs.push(new quest_giver_npc())

  tune(game_config.music_main_theme)

  print("Game initialised. Welcome to " + game_config.title + "!")
  transit("menu")
end

// Main update loop. during blocks run only in their matching state.
// This prevents mixed state logic and keeps each screen self-contained.
update() = function

  during "menu" do
    screen.clear("#000033")
    screen.text(game_config.title)
    screen.text("Press SPACE to start")
    screen.text("Press L to load game")

    if key("space").hit then
      sfx("menu_select")
      transit("game")
    end
    if key("l").hit then
      sfx("menu_select")
      player.load_progress()
      transit("game")
    end
  end

  during "game" do
    screen.clear("rgb(20, 30, 40)")

    player.move()
    player.interact()

    if key("h").hit then player.use_potion() end
    if key("s").hit then player.save_progress() end

    if key("p").hit then
      sfx("pause_toggle")
      transit("paused")
    end

    local collected_crystal = collide("collectible")
    if collected_crystal then
      collected_crystal.collect(player)
    end

    if player.crystals_found >= game_config.max_crystals then
      transit("win")
    end

    for e in enemies
      e.update(player.x, player.y)
    end

    // attempt and recover handle risky logic gracefully.
    // If anything in the attempt block fails, recover runs instead of crashing.
    if key("r").hit then
      sfx(game_config.sfx_risky_action)
      attempt
        local chance = random(100)
        if chance < 30 then
          local x = undefined_variable.value
        end
        player.score += 500
        print("Risky action succeeded! +500 score.")
      recover
        print("Risky action failed!")
        sfx(game_config.sfx_risky_fail)
        player.take_damage(20)
      end
    end

    // view offsets all draws inside the block by the camera position.
    view x=player.x, y=player.y do
      player.draw()
      for e in enemies
        e.draw()
      end
      for c in crystals
        c.draw()
      end
      for n in npcs
        n.draw()
      end
    end

    screen.text("Score: " + player.score)
    screen.text("Crystals: " + player.crystals_found + "/" + game_config.max_crystals)

    // elsetry creates a clean waterfall of conditions without nested ifs.
    if player.hp > game_config.initial_player_hp * 0.7 then
      screen.text("Status: Healthy")
    elsetry player.hp > game_config.initial_player_hp * 0.3 then
      screen.text("Status: Injured")
      alter opacity=0.1, color="red" do
        screen.fillRect(0, 0, 300, 200)
      end
    else
      screen.text("Status: Critical!")
      alter opacity=0.2, color="red" do
        screen.fillRect(0, 0, 300, 200)
      end
    end
  end

  during "paused" do
    screen.clear("#111")
    screen.text("PAUSED")
    screen.text("Press P to resume")
    silence(game_config.music_main_theme)

    if key("p").hit then
      sfx("pause_toggle")
      tune(game_config.music_main_theme)
      transit("game")
    end
  end

  during "gameOver" do
    silence("all")
    screen.clear("black")
    screen.text("GAME OVER")
    screen.text("Score: " + player.score)
    screen.text("Press SPACE to restart")
    sfx(game_config.sfx_game_over)

    if key("space").hit then
      init()
    end
  end

  during "win" do
    silence("all")
    screen.clear("rgb(0, 50, 0)")
    screen.text("VICTORY!")
    screen.text("You restored the Crystal of Harmony!")
    screen.text("Final Score: " + player.score)
    screen.text("Press SPACE to return to menu")
    sfx(game_config.sfx_victory)

    if key("space").hit then
      init()
      transit("menu")
    end
  end

end
